<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.AddProjectView"
             x:DataType="vm:AddProjectViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  MaxHeight="360">
        <StackPanel Spacing="16"
                    MaxWidth="480"
                    HorizontalAlignment="Stretch">

            <StackPanel Spacing="4">
                <TextBlock Text="Name" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <TextBox Text="{Binding Name}" PlaceholderText="My App" IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Git URL" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <TextBox Text="{Binding GitUrl}"
                         PlaceholderText="https://github.com/org/repo.git"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Branch" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <TextBox Text="{Binding Branch}" PlaceholderText="main" IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Polling interval (minutes, 0 = manual only)" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <TextBox Text="{Binding PollingInterval}" PlaceholderText="0" IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Access token (optional, for private HTTPS repos)" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                <TextBox Text="{Binding GitToken}"
                         PasswordChar="●"
                         PlaceholderText="Personal access token"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <TextBlock Text="{Binding Error}"
                       Foreground="Red"
                       IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>

</UserControl>
