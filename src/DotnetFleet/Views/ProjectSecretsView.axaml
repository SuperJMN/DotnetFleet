<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.ProjectSecretsView"
             x:DataType="vm:ProjectSecretsViewModel">

    <DockPanel Margin="8">

        <FlexPanel DockPanel.Dock="Top"
                   Wrap="Wrap"
                   Gap="8"
                   AlignItems="Center"
                   Margin="0,0,0,8">
            <StackPanel Spacing="2"
                        FlexPanel.Grow="1"
                        MinWidth="180">
                <TextBlock Text="Project Secrets"
                           FontWeight="SemiBold" />
                <TextBlock Text="Overrides global secrets"
                           FontSize="11"
                           Opacity="0.65" />
            </StackPanel>
            <EnhancedButton Icon="{Icon mdi-refresh}"
                            ToolTip.Tip="Refresh"
                            Command="{Binding RefreshCommand}" />
        </FlexPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding Error}"
                   Foreground="Red"
                   FontSize="11"
                   Margin="0,0,0,4"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,4" />

        <FlexPanel DockPanel.Dock="Top"
                   Wrap="Wrap"
                   Gap="4"
                   AlignItems="Center"
                   Margin="0,0,0,8">
            <TextBox Text="{Binding NewName}"
                     PlaceholderText="Name (e.g. NUGET_API_KEY)"
                     FlexPanel.Grow="1"
                     MinWidth="160" />
            <TextBox Text="{Binding NewValue}"
                     PlaceholderText="Value"
                     PasswordChar="●"
                     FlexPanel.Grow="1"
                     MinWidth="160" />
            <EnhancedButton Content="Add"
                            Icon="{Icon mdi-plus}"
                            Classes="Primary"
                            Command="{Binding AddCommand}" />
        </FlexPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Secrets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ProjectSecretViewModel">
                        <Border Padding="8,6"
                                Margin="0,2"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <Panel>
                                <FlexPanel Wrap="Wrap"
                                           Gap="4"
                                           AlignItems="Center"
                                           IsVisible="{Binding !IsEditing}">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FlexPanel.Grow="1"
                                               MinWidth="120" />
                                    <EnhancedButton Icon="{Icon mdi-pencil}"
                                                    ToolTip.Tip="Edit"
                                                    Command="{Binding EditCommand}"
                                                    Padding="4,2" />
                                    <EnhancedButton Icon="{Icon mdi-close}"
                                                    ToolTip.Tip="Delete"
                                                    Classes="Destructive"
                                                    Command="{Binding DeleteCommand}"
                                                    Padding="4,2" />
                                </FlexPanel>

                                <FlexPanel Wrap="Wrap"
                                           Gap="4"
                                           AlignItems="Center"
                                           IsVisible="{Binding IsEditing}">
                                    <StackPanel Spacing="2"
                                                FlexPanel.Grow="1"
                                                MinWidth="140">
                                        <TextBox Text="{Binding Name}"
                                                 PlaceholderText="Name"
                                                 FontSize="12" />
                                        <TextBox Text="{Binding Value}"
                                                 PlaceholderText="Value"
                                                 FontSize="12" />
                                    </StackPanel>
                                    <EnhancedButton Icon="{Icon mdi-check}"
                                                    ToolTip.Tip="Save"
                                                    Classes="Primary"
                                                    Command="{Binding SaveCommand}"
                                                    Padding="4,2" />
                                    <EnhancedButton Icon="{Icon mdi-close}"
                                                    ToolTip.Tip="Cancel"
                                                    Classes="Cancel"
                                                    Command="{Binding CancelCommand}"
                                                    Padding="4,2" />
                                </FlexPanel>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
