<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.SecretsView"
             x:DataType="vm:SecretsViewModel">

    <DockPanel Margin="16">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <TextBlock Grid.Column="0" Text="Global Secrets" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="↺" Command="{Binding RefreshCommand}" />
        </Grid>

        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Add new secret -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="4" Padding="12" Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Add secret"
                           FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding NewName}"
                         Watermark="Name (e.g. GITHUB_TOKEN)"
                         Margin="0,0,8,0" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding NewValue}"
                         Watermark="Value"
                         PasswordChar="●"
                         Margin="0,0,8,0" />
                <Button Grid.Row="1" Grid.Column="2"
                        Content="Add"
                        Command="{Binding AddCommand}" />
            </Grid>
        </Border>

        <!-- Secret list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Secrets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SecretViewModel">
                        <Border Padding="12,8" Margin="0,2"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <Panel>
                                <!-- View mode -->
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                      IsVisible="{Binding !IsEditing}">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               FontFamily="Consolas,monospace"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="●●●●●●●●"
                                               Opacity="0.5" Margin="12,0" VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Content="Edit"
                                            Command="{Binding EditCommand}"
                                            Margin="0,0,4,0" />
                                    <Button Grid.Column="3" Content="Delete"
                                            Command="{Binding DeleteCommand}" />
                                </Grid>

                                <!-- Edit mode -->
                                <Grid ColumnDefinitions="*,*,Auto,Auto"
                                      IsVisible="{Binding IsEditing}">
                                    <TextBox Grid.Column="0" Text="{Binding Name}"
                                             Watermark="Name" Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1" Text="{Binding Value}"
                                             Watermark="Value" Margin="0,0,8,0" />
                                    <Button Grid.Column="2" Content="Save"
                                            Command="{Binding SaveCommand}"
                                            Margin="0,0,4,0" />
                                    <Button Grid.Column="3" Content="Cancel"
                                            Command="{Binding CancelCommand}" />
                                </Grid>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
