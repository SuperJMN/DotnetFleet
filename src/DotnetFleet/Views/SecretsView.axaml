<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.SecretsView"
             x:DataType="vm:SecretsViewModel">

    <DockPanel Margin="16">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <TextBlock Grid.Column="0" Text="Global Secrets" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="↺" Command="{Binding RefreshCommand}" />
        </Grid>

        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Two header forms: side-by-side on wide, stacked on narrow -->
        <BalancedWrapGrid DockPanel.Dock="Top"
                          MinItemWidth="300"
                          HorizontalSpacing="8"
                          VerticalSpacing="8"
                          Margin="0,0,0,8">
            <!-- Add new secret -->
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Add secret" FontWeight="SemiBold" />
                    <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                        <TextBox Text="{Binding NewName}"
                                 Watermark="Name (e.g. GITHUB_TOKEN)"
                                 MinWidth="160"
                                 FlexPanel.Grow="1" />
                        <TextBox Text="{Binding NewValue}"
                                 Watermark="Value"
                                 PasswordChar="●"
                                 MinWidth="160"
                                 FlexPanel.Grow="1" />
                        <Button Content="Add"
                                Command="{Binding AddCommand}" />
                    </FlexPanel>
                </StackPanel>
            </Border>

            <!-- Import from .env -->
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Import from .env" FontWeight="SemiBold" />
                    <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                        <TextBox Text="{Binding EnvFilePath}"
                                 Watermark="Absolute path to .env"
                                 MinWidth="200"
                                 FlexPanel.Grow="1" />
                        <Button Content="Import"
                                Command="{Binding ImportFromEnvCommand}" />
                    </FlexPanel>
                </StackPanel>
            </Border>
        </BalancedWrapGrid>

        <!-- Secret list: card grid -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Secrets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <BalancedWrapGrid MinItemWidth="300"
                                          HorizontalSpacing="8"
                                          VerticalSpacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SecretViewModel">
                        <Border Padding="12,8"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <Panel>
                                <!-- View mode -->
                                <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center"
                                           IsVisible="{Binding !IsEditing}">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Consolas,monospace"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FlexPanel.Grow="1" MinWidth="120" />
                                    <TextBlock Text="●●●●●●●●"
                                               Opacity="0.5" VerticalAlignment="Center" />
                                    <Button Content="Edit"
                                            Command="{Binding EditCommand}" />
                                    <Button Content="Delete"
                                            Command="{Binding DeleteCommand}" />
                                </FlexPanel>

                                <!-- Edit mode -->
                                <FlexPanel Wrap="Wrap" Gap="4" AlignItems="Center"
                                           IsVisible="{Binding IsEditing}">
                                    <TextBox Text="{Binding Name}"
                                             Watermark="Name"
                                             FlexPanel.Grow="1" MinWidth="100" />
                                    <TextBox Text="{Binding Value}"
                                             Watermark="Value"
                                             FlexPanel.Grow="1" MinWidth="100" />
                                    <Button Content="Save"
                                            Command="{Binding SaveCommand}" />
                                    <Button Content="Cancel"
                                            Command="{Binding CancelCommand}" />
                                </FlexPanel>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
