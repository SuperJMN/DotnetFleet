<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.WorkersView"
             x:DataType="vm:WorkersViewModel">

    <DockPanel Margin="16">

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <ListBox ItemsSource="{Binding Workers}" Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <BalancedWrapGrid MinItemWidth="320"
                                      HorizontalSpacing="8"
                                      VerticalSpacing="8"
                                      VerticalAlignment="Top" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:WorkerItemViewModel">
                    <Border Padding="12"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <FlexPanel Wrap="Wrap" Gap="12" AlignItems="Center">
                            <StackPanel Spacing="4" MinWidth="200" FlexPanel.Grow="1">
                                <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                                    <TextBlock Text="{Binding Worker.Name}"
                                               FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding EmbeddedLabel}"
                                               Opacity="0.5" FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Worker.Version, StringFormat='v{0}'}"
                                               IsVisible="{Binding Worker.Version, Converter={x:Static ObjectConverters.IsNotNull}}"
                                               Opacity="0.6" FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="220" />
                                </FlexPanel>
                                <TextBlock Text="{Binding StatusLabel}" FontSize="12" />
                                <TextBlock FontSize="11" Opacity="0.6">
                                    <Run Text="Last seen: " />
                                    <Run Text="{Binding Worker.LastSeenAt}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Disk config -->
                            <StackPanel Spacing="4" MinWidth="200">
                                <TextBlock Text="Max disk (GB)" FontSize="11" Opacity="0.7" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <NumericUpDown Grid.Column="0"
                                                   Value="{Binding MaxDiskUsageGb}"
                                                   Minimum="1" Maximum="500" Increment="1"
                                                   FormatString="N0" />
                                    <EnhancedButton Grid.Column="1"
                                                    Content="Save"
                                                    Icon="{Icon mdi-content-save}"
                                                    Classes="Primary"
                                                    Command="{Binding SaveConfigCommand}"
                                                    IsEnabled="{Binding !IsSaving}" />
                                </Grid>
                            </StackPanel>
                        </FlexPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>

</UserControl>
