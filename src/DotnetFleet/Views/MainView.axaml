<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.MainView"
             x:DataType="vm:MainViewModel">

    <DockPanel>

        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="16,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="DotnetFleet"
                           FontWeight="Bold" FontSize="16"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="24,0">
                    <Button Content="Projects"
                            Command="{Binding SelectProjectsCommand}"
                            Classes="tab" />
                    <Button Content="Workers"
                            Command="{Binding SelectWorkersCommand}"
                            Classes="tab" />
                </StackPanel>
                <Button Grid.Column="2" Content="Sign out"
                        Command="{Binding LogoutCommand}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Content area -->
        <ContentControl Content="{Binding CurrentContent}" />

    </DockPanel>

</UserControl>
