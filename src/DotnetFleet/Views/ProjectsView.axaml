<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             xmlns:icons="clr-namespace:Optris.Icons.Avalonia;assembly=Optris.Icons.Avalonia"
             xmlns:converters="clr-namespace:DotnetFleet.Converters"
             x:Class="DotnetFleet.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel">

    <DockPanel Margin="16">

        <!-- Loading indicator -->
        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Project list: card grid that adapts column count to width -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <BalancedWrapGrid MinItemWidth="280"
                                          HorizontalSpacing="8"
                                          VerticalSpacing="8"
                                          VerticalAlignment="Top" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ProjectViewModel">
                    <Border Padding="12"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="6"
                                    ClipToBounds="True"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Image Source="{Binding ProjectIconBytes, Converter={x:Static converters:ProjectIconConverters.ByteArrayToBitmap}}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding HasProjectIcon}" />
                                    <icons:Icon Value="mdi-folder-outline"
                                                Width="22"
                                                Height="22"
                                                Opacity="0.65"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding HasNoProjectIcon}" />
                                </Grid>
                            </Border>
                            <StackPanel Spacing="4" MinWidth="200" FlexPanel.Grow="1">
                                <TextBlock Text="{Binding Project.Name}"
                                           FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{Binding Project.GitUrl}"
                                           Opacity="0.6" FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Opacity="0.5">
                                    <Run Text="Branch: " />
                                    <Run Text="{Binding Project.Branch}" />
                                    <Run Text="  |  Polling: " />
                                    <Run Text="{Binding Project.PollingIntervalMinutes}" />
                                    <Run Text=" min" />
                                </TextBlock>
                            </StackPanel>
                            <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                                <EnhancedButton Content="Open" Icon="{Icon mdi-folder-open-outline}" Classes="Primary" Command="{Binding OpenCommand}" />
                                <EnhancedButton ToolTip.Tip="Edit" Command="{Binding EditCommand}">
                                    <icons:Icon Value="mdi-pencil" />
                                </EnhancedButton>
                                <EnhancedButton ToolTip.Tip="Delete" Classes="Destructive" Command="{Binding DeleteCommand}">
                                    <icons:Icon Value="mdi-delete-outline" />
                                </EnhancedButton>
                            </FlexPanel>
                        </FlexPanel>
                    </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
