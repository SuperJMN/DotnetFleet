<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             xmlns:conv="clr-namespace:DotnetFleet.Converters"
             x:Class="DotnetFleet.Views.MainShell"
             x:DataType="vm:AppViewModel">

    <DockPanel>

        <!-- Backend health status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Button Command="{Binding ReconnectCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand"
                    ToolTip.Tip="Click to change endpoint or reconnect">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                    <Ellipse Grid.Column="0"
                             Width="10" Height="10"
                             VerticalAlignment="Center"
                             Fill="{Binding BackendHealth, Converter={x:Static conv:HealthConverters.ToBrush}}" />
                    <TextBlock Grid.Column="1"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="{Binding BackendHealth, Converter={x:Static conv:HealthConverters.ToLabel}}" />
                    <TextBlock Grid.Column="2"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding BackendEndpoint}" />
                    <TextBlock Grid.Column="3"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               FontSize="11"
                               Text="{Binding BackendVersion, StringFormat='v{0}'}"
                               IsVisible="{Binding BackendVersion, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <TextBlock Grid.Column="4"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               FontSize="11"
                               Text="{Binding BackendHealthMessage}"
                               IsVisible="{Binding BackendHealthMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                </Grid>
            </Button>
        </Border>

        <ContentControl Content="{Binding CurrentPage}" />

    </DockPanel>

</UserControl>
