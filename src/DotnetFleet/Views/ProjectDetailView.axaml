<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.ProjectDetailView"
             x:DataType="vm:ProjectDetailViewModel">

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Main content: jobs + project secrets. Side-by-side on wide, stacked on narrow. -->
        <FlexPanel Direction="Row" Wrap="Wrap" Gap="12" AlignItems="Stretch">

            <!-- Job list -->
            <ListBox FlexPanel.Grow="1" FlexPanel.Basis="320" MinWidth="280"
                     ItemsSource="{Binding Jobs}" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:JobViewModel">
                        <Border Padding="12,8" Margin="0,2"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <FlexPanel Wrap="Wrap" Gap="12" AlignItems="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center" MinWidth="140">
                                    <ContentControl Content="{Binding StatusIcon}"
                                                    IconOptions.Fill="{Binding StatusBrush}"
                                                    IconOptions.Size="16"
                                                    VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Spacing="2"
                                            MinWidth="180" FlexPanel.Grow="1">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock FontSize="12" Opacity="0.6">
                                        <Run Text="Queued: " />
                                        <Run Text="{Binding Job.EnqueuedAt}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Opacity="0.5"
                                               IsVisible="{Binding Job.TriggerCommitSha, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Run Text="SHA: " />
                                        <Run Text="{Binding Job.TriggerCommitSha}" />
                                    </TextBlock>
                                </StackPanel>
                                <EnhancedButton Content="View Logs" Icon="{Icon mdi-text-box-outline}" Classes="Primary" Command="{Binding OpenCommand}" />
                            </FlexPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Project secrets panel -->
            <DockPanel FlexPanel.Grow="1" FlexPanel.Basis="280"
                       MinWidth="240" MaxWidth="400"
                       DataContext="{Binding ProjectSecrets}">

                <!-- Secrets header -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="Project Secrets" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <EnhancedButton Grid.Column="1" Icon="{Icon mdi-refresh}" Command="{Binding RefreshCommand}" />
                </Grid>

                <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                           Foreground="Red" FontSize="11" Margin="0,0,0,4"
                           IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" Height="3" Margin="0,0,0,4" />

                <!-- Add new project secret -->
                <Grid DockPanel.Dock="Top" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                    <TextBox Grid.Row="0" Text="{Binding NewName}"
                             Watermark="Name (e.g. NUGET_API_KEY)"
                             Margin="0,0,0,4" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewValue}"
                                 Watermark="Value" PasswordChar="●"
                                 Margin="0,0,4,0" />
                        <EnhancedButton Grid.Column="1" Content="Add" Icon="{Icon mdi-plus}"
                                        Classes="Primary"
                                        Command="{Binding AddCommand}" />
                    </Grid>
                </Grid>

                <!-- Project secret list -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Secrets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ProjectSecretViewModel">
                                <Border Padding="8,6" Margin="0,2"
                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        CornerRadius="4">
                                    <Panel>
                                        <!-- View mode -->
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              IsVisible="{Binding !IsEditing}">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontFamily="Consolas,monospace" FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <EnhancedButton Grid.Column="1" Icon="{Icon mdi-pencil}"
                                                            Command="{Binding EditCommand}"
                                                            Margin="4,0,2,0" Padding="4,2" />
                                            <EnhancedButton Grid.Column="2" Icon="{Icon mdi-close}"
                                                            Classes="Destructive"
                                                            Command="{Binding DeleteCommand}"
                                                            Padding="4,2" />
                                        </Grid>

                                        <!-- Edit mode -->
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              IsVisible="{Binding IsEditing}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBox Text="{Binding Name}" Watermark="Name" FontSize="12" />
                                                <TextBox Text="{Binding Value}" Watermark="Value" FontSize="12" />
                                            </StackPanel>
                                            <EnhancedButton Grid.Column="1" Icon="{Icon mdi-check}"
                                                            Classes="Primary"
                                                            Command="{Binding SaveCommand}"
                                                            Margin="4,0,2,0" Padding="4,2" />
                                            <EnhancedButton Grid.Column="2" Icon="{Icon mdi-close}"
                                                            Classes="Cancel"
                                                            Command="{Binding CancelCommand}"
                                                            Padding="4,2" />
                                        </Grid>
                                    </Panel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>

        </FlexPanel>

    </DockPanel>

</UserControl>
