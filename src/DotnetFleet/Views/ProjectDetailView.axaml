<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.ProjectDetailView"
             x:DataType="vm:ProjectDetailViewModel">

    <DockPanel Margin="16">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="0,0,0,16">
            <Button Grid.Column="0" Content="← Back" Command="{Binding BackCommand}" Margin="0,0,12,0" />
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding Project.Name}" FontSize="20" FontWeight="Bold" />
                <TextBlock FontSize="12" Opacity="0.6">
                    <Run Text="{Binding Project.GitUrl}" />
                    <Run Text=" @ " />
                    <Run Text="{Binding Project.Branch}" />
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="2" Content="✏ Edit" Command="{Binding EditCommand}" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="🧹 Clear finished"
                    Command="{Binding ClearFinishedJobsCommand}"
                    ToolTip.Tip="Delete all jobs that have already finished (succeeded, failed or cancelled)."
                    Margin="0,0,8,0" />
            <Button Grid.Column="4" Content="↺" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
            <Button Grid.Column="5" Content="🚀 Deploy Now" Command="{Binding DeployCommand}" />
        </Grid>

        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Main content: jobs (left) + project secrets (right) -->
        <Grid ColumnDefinitions="*,Auto,300">

            <!-- Job list -->
            <ListBox Grid.Column="0" ItemsSource="{Binding Jobs}" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:JobViewModel">
                        <Border Padding="12,8" Margin="0,2"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding StatusBadge}"
                                           FontFamily="Consolas,monospace" VerticalAlignment="Center"
                                           MinWidth="140" />
                                <StackPanel Grid.Column="1" Spacing="2" Margin="12,0">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock FontSize="12" Opacity="0.6">
                                        <Run Text="Queued: " />
                                        <Run Text="{Binding Job.EnqueuedAt}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Opacity="0.5"
                                               IsVisible="{Binding Job.TriggerCommitSha, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Run Text="SHA: " />
                                        <Run Text="{Binding Job.TriggerCommitSha}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="2" Content="View Logs" Command="{Binding OpenCommand}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

            <!-- Project secrets panel -->
            <DockPanel Grid.Column="2" Margin="12,0,0,0"
                       DataContext="{Binding ProjectSecrets}">

                <!-- Secrets header -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="Project Secrets" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="↺" Command="{Binding RefreshCommand}" />
                </Grid>

                <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                           Foreground="Red" FontSize="11" Margin="0,0,0,4"
                           IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}" Height="3" Margin="0,0,0,4" />

                <!-- Add new project secret -->
                <Grid DockPanel.Dock="Top" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                    <TextBox Grid.Row="0" Text="{Binding NewName}"
                             Watermark="Name (e.g. NUGET_API_KEY)"
                             Margin="0,0,0,4" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewValue}"
                                 Watermark="Value" PasswordChar="●"
                                 Margin="0,0,4,0" />
                        <Button Grid.Column="1" Content="Add"
                                Command="{Binding AddCommand}" />
                    </Grid>
                </Grid>

                <!-- Project secret list -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Secrets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ProjectSecretViewModel">
                                <Border Padding="8,6" Margin="0,2"
                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        CornerRadius="4">
                                    <Panel>
                                        <!-- View mode -->
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              IsVisible="{Binding !IsEditing}">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontFamily="Consolas,monospace" FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="✏" FontSize="11"
                                                    Command="{Binding EditCommand}"
                                                    Margin="4,0,2,0" Padding="4,2" />
                                            <Button Grid.Column="2" Content="✕" FontSize="11"
                                                    Command="{Binding DeleteCommand}"
                                                    Padding="4,2" />
                                        </Grid>

                                        <!-- Edit mode -->
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              IsVisible="{Binding IsEditing}">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBox Text="{Binding Name}" Watermark="Name" FontSize="12" />
                                                <TextBox Text="{Binding Value}" Watermark="Value" FontSize="12" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="✓" FontSize="11"
                                                    Command="{Binding SaveCommand}"
                                                    Margin="4,0,2,0" Padding="4,2" />
                                            <Button Grid.Column="2" Content="✕" FontSize="11"
                                                    Command="{Binding CancelCommand}"
                                                    Padding="4,2" />
                                        </Grid>
                                    </Panel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>

        </Grid>

    </DockPanel>

</UserControl>
