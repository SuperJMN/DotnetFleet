<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.ViewModels"
             x:Class="DotnetFleet.Views.ProjectDetailView"
             x:DataType="vm:ProjectDetailViewModel">

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                   Foreground="Red" Margin="0,0,0,8"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}" Height="4" Margin="0,0,0,8" />

        <!-- Main content: jobs + project secrets. Side-by-side on wide, stacked on narrow. -->
        <FlexPanel Direction="Row" Wrap="Wrap" Gap="12" AlignItems="Stretch">

            <!-- Job list -->
            <ScrollViewer FlexPanel.Grow="1" FlexPanel.Basis="320" MinWidth="280">
                <ItemsControl ItemsSource="{Binding Jobs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:JobViewModel">
                        <Border Padding="12,8" Margin="0,2"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="4">
                            <FlexPanel Wrap="Wrap" Gap="12" AlignItems="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center" MinWidth="140">
                                    <ContentControl Content="{Binding StatusIcon}"
                                                    IconOptions.Fill="{Binding StatusBrush}"
                                                    IconOptions.Size="16"
                                                    VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{Binding StatusBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Spacing="2"
                                            MinWidth="180" FlexPanel.Grow="1">
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock FontSize="12" Opacity="0.6">
                                        <Run Text="{Binding KindText}" />
                                        <Run Text=" · Queued: " />
                                        <Run Text="{Binding Job.EnqueuedAt}" />
                                    </TextBlock>
                                    <TextBlock FontSize="12" Opacity="0.5"
                                               IsVisible="{Binding Job.TriggerCommitSha, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Run Text="SHA: " />
                                        <Run Text="{Binding Job.TriggerCommitSha}" />
                                    </TextBlock>
                                </StackPanel>
                                <EnhancedButton Content="View Logs" Icon="{Icon mdi-text-box-outline}" Classes="Primary" Command="{Binding OpenCommand}" />
                            </FlexPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>

            <!-- Project actions sidebar -->
            <TabControl FlexPanel.Grow="1" FlexPanel.Basis="280"
                        MinWidth="240" MaxWidth="420">
                <TabItem Header="Deploy">
                    <!-- Project secrets panel -->
                    <DockPanel DataContext="{Binding ProjectSecrets}">

                        <!-- Secrets header -->
                        <FlexPanel DockPanel.Dock="Top" Wrap="Wrap" Gap="8"
                                   AlignItems="Center" Margin="0,0,0,8">
                            <TextBlock Text="Project Secrets" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       FlexPanel.Grow="1" MinWidth="140" />
                            <EnhancedButton Icon="{Icon mdi-refresh}" Command="{Binding RefreshCommand}" />
                        </FlexPanel>

                        <TextBlock DockPanel.Dock="Top" Text="{Binding Error}"
                                   Foreground="Red" FontSize="11" Margin="0,0,0,4"
                                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />

                        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                                     IsVisible="{Binding IsLoading}" Height="3" Margin="0,0,0,4" />

                        <!-- Add new project secret -->
                        <FlexPanel DockPanel.Dock="Top" Wrap="Wrap" Gap="4"
                                   AlignItems="Center" Margin="0,0,0,8">
                            <TextBox Text="{Binding NewName}"
                                     PlaceholderText="Name (e.g. NUGET_API_KEY)"
                                     FlexPanel.Grow="1" MinWidth="160" />
                            <TextBox Text="{Binding NewValue}"
                                     PlaceholderText="Value" PasswordChar="●"
                                     FlexPanel.Grow="1" MinWidth="160" />
                            <EnhancedButton Content="Add" Icon="{Icon mdi-plus}"
                                            Classes="Primary"
                                            Command="{Binding AddCommand}" />
                        </FlexPanel>

                        <!-- Project secret list -->
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Secrets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ProjectSecretViewModel">
                                        <Border Padding="8,6" Margin="0,2"
                                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                                CornerRadius="4">
                                            <Panel>
                                                <!-- View mode -->
                                                <FlexPanel Wrap="Wrap" Gap="4" AlignItems="Center"
                                                           IsVisible="{Binding !IsEditing}">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="Consolas,monospace" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               FlexPanel.Grow="1" MinWidth="120" />
                                                    <EnhancedButton Icon="{Icon mdi-pencil}"
                                                                    Command="{Binding EditCommand}"
                                                                    Padding="4,2" />
                                                    <EnhancedButton Icon="{Icon mdi-close}"
                                                                    Classes="Destructive"
                                                                    Command="{Binding DeleteCommand}"
                                                                    Padding="4,2" />
                                                </FlexPanel>

                                                <!-- Edit mode -->
                                                <FlexPanel Wrap="Wrap" Gap="4" AlignItems="Center"
                                                           IsVisible="{Binding IsEditing}">
                                                    <StackPanel Spacing="2" FlexPanel.Grow="1" MinWidth="140">
                                                        <TextBox Text="{Binding Name}" PlaceholderText="Name" FontSize="12" />
                                                        <TextBox Text="{Binding Value}" PlaceholderText="Value" FontSize="12" />
                                                    </StackPanel>
                                                    <EnhancedButton Icon="{Icon mdi-check}"
                                                                    Classes="Primary"
                                                                    Command="{Binding SaveCommand}"
                                                                    Padding="4,2" />
                                                    <EnhancedButton Icon="{Icon mdi-close}"
                                                                    Classes="Cancel"
                                                                    Command="{Binding CancelCommand}"
                                                                    Padding="4,2" />
                                                </FlexPanel>
                                            </Panel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </DockPanel>
                </TabItem>

                <TabItem Header="Build">
                    <ScrollViewer>
                        <Border Padding="12"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="4">
                            <StackPanel Spacing="10">
                                <FlexPanel Wrap="Wrap" Gap="8" AlignItems="Center">
                                    <TextBlock Text="Package Targets" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               FlexPanel.Grow="1" MinWidth="140" />
                                    <EnhancedButton Content="Build" Icon="{Icon mdi-package-variant-closed}"
                                                    Classes="Primary"
                                                    Command="{Binding BuildPackagesCommand}" />
                                </FlexPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Package project" FontWeight="SemiBold" FontSize="12" Opacity="0.75" />
                                    <ComboBox ItemsSource="{Binding PackageProjects}"
                                              SelectedItem="{Binding PackageProject}"
                                              IsVisible="{Binding HasPackageProjects}"
                                              HorizontalAlignment="Stretch" />
                                    <TextBox Text="{Binding PackageProject}"
                                             PlaceholderText="github.packages project path (optional)" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding PackagePlatforms}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PackagePlatformViewModel">
                                            <StackPanel Spacing="4" Margin="0,2,0,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Opacity="0.75" />
                                                <ItemsControl ItemsSource="{Binding Formats}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:PackageFormatViewModel">
                                                            <StackPanel Spacing="2" Margin="0,2,0,4">
                                                                <TextBlock Text="{Binding Label}" FontSize="12" />
                                                                <ItemsControl ItemsSource="{Binding Architectures}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="vm:PackageTargetOptionViewModel">
                                                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="8,1,0,1">
                                                                                <TextBlock Text="{Binding ArchitectureLabel}" Opacity="0.65" />
                                                                            </CheckBox>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

        </FlexPanel>

    </DockPanel>

</UserControl>
