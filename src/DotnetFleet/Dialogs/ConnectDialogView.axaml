<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DotnetFleet.Dialogs"
             x:Class="DotnetFleet.Dialogs.ConnectDialogView"
             x:DataType="vm:ConnectDialogViewModel"
             Width="380">

    <StackPanel Spacing="12">

        <TextBlock Text="Enter the coordinator endpoint URL:" Opacity="0.7" />

        <TextBox Text="{Binding EndpointUrl}"
                 Watermark="http://localhost:5000"
                 IsEnabled="{Binding !IsBusy}" />

        <ProgressBar IsIndeterminate="True" Height="4"
                     IsVisible="{Binding IsBusy}" />

        <TextBlock Text="{Binding Error}"
                   Foreground="Red"
                   IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}"
                   TextWrapping="Wrap" />

    </StackPanel>

</UserControl>
