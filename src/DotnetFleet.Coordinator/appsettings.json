{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fleet.db"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "DotnetFleet",
    "Audience": "DotnetFleet",
    "ExpiryHours": 24
  },
  "EmbedWorker": true,
  "Worker": {
    "RepoStoragePath": "fleet-repos",
    "HeartbeatIntervalSeconds": 30,
    "PollIntervalSeconds": 10
  },
  "Seed": {
    "AdminPassword": "admin"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
